# Software License Manager - Environment Configuration
# Copy this file to .env and adjust values for your environment

# Application
APP_NAME=Software License Manager
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# Security - CHANGE THESE IN PRODUCTION!
SECRET_KEY=change-this-secret-key-in-production-make-it-long-and-secure
JWT_SECRET=change-this-jwt-secret-in-production-make-it-long-and-secure

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/license_manager.db
# POSTGRES_URL=postgresql+asyncpg://user:password@localhost:5432/license_manager

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
CORS_ORIGINS=["*"]

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRY=60

# Encryption
RSA_KEY_SIZE=4096
AES_KEY_SIZE=256

# Paths
LICENSE_DIR=./licenses
LOG_DIR=./logs
BACKUP_DIR=./backups

# Logging
LOG_LEVEL=DEBUG

# Security
MAX_LOGIN_ATTEMPTS=5
RATE_LIMIT=60